    "Thanks paragraph" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich danke recht herzlich den folgenden Leuten für die Unterstützung und Hilfe: Tobias Strunz, Robin Dinse, Fabian Schuiki, Georg Schoelly, Michael Schwarz, Mirco Sina, Matthieu Riolo, meine Klassenkameraden (besonders Ingmar Stupp) und der Rest."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Many thanks to the following people for their support and help: Tobias Strunz, Robin Dinse, Fabian Schuiki, Georg Schoelly, Michael Schwarz, Mirco Sina, Matthieu Riolo, my classmates (especially Ingmar Stupp) and the rest."
          }
        }
      }
    },
